# LiveKit self-hosted server config — copy to livekit.yaml and fill in your values
# Docs: https://docs.livekit.io/home/self-hosting/deployment/

port: 7880
bind_addresses:
  - ""

# Must match LIVEKIT_API_KEY: LIVEKIT_API_SECRET in backend/.env
keys:
  your-api-key: your-api-secret

rtc:
  port_range_start: 50100
  port_range_end: 50200
  # Uncomment and set when deploying to a VPS:
  # node_ip: "YOUR_PUBLIC_IP"

room:
  empty_timeout: 300
  max_participants: 20

logging:
  level: info
  json: false
